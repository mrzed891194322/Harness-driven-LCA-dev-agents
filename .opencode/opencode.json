{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "major-orchestrator",
  "instructions": [
    "harness/rules/directory-structure/README.md",
    "harness/rules/coding-specification/README.md",
    "harness/rules/knowledge-retrieval/README.md"
  ],
  "mcp": {
    "query_rag": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "python",
        "harness/tools/query_rag/main.py"
      ],
      "enabled": true
    },
    "control_openlca": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "python",
        "harness/tools/control_openlca/main.py"
      ],
      "enabled": true
    }
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "major-orchestrator": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.3
    },
    "sub-executor": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.2
    },
    "eval-reviewer": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1
    }
  }
}
