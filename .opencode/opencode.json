{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "instructions": [
    "harness/rules/subagent-invocation/README.md",
    "harness/rules/directory-structure/README.md",
    "harness/rules/coding-specification/README.md"
  ],
  "mcp": {
    "servers": {
      "query_rag": {
        "type": "local",
        "command": [
          "uv",
          "run",
          "python",
          "/home/yuandu/Programming/202606-harness-agent-LCA/harness/tools/query_rag/main.py"
        ],
        "disabled": false
      }
    }
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": false
    },
    "plan-maker": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.5
    },
    "LCI-designer": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.45
    },
    "subagents/workflow/data-processor": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.2
    },
    "subagents/workflow/eval-executor": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1
    },
    "subagents/tools/code-builder": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.1
    },
    "subagents/tools/doc-handler": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.1
    },
  }
}